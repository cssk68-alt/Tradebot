# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# Anthropic API key for the LLM agents. If empty, the bot falls back to
# heuristic sentiment/prediction so it still runs in paper mode.
ANTHROPIC_API_KEY=

# Execution mode: paper (default, simulated, no real money) or live.
MODE=paper
BANKROLL=1000

# --- Live mode only (Polymarket on Polygon). Never commit real values. ---
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# --- Strategy knobs ---
KELLY_FRACTION=0.25
MAX_TRADE_PCT=0.05
MAX_EXPOSURE_PCT=0.5
MIN_LIQUIDITY=500
MIN_VOLUME_24H=1000
EDGE_THRESHOLD=0.05
CONFIDENCE_THRESHOLD=0.6
BRAIN_WEIGHT=0.3
BRAIN_VETO_THRESHOLD=0.35
MAX_SLIPPAGE=0.02
MIN_DAYS_TO_RESOLUTION=1
MAX_DAYS_TO_RESOLUTION=30
