# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# --- LLM agent (REQUIRED) ---
# The bot is a coupled Brain+Agent system: without an LLM agent it HARD-FAILS at
# startup (no auto-approve, no neutral-only run). Pick a provider and set the
# MATCHING key below. DeepSeek is the default — ~10x cheaper for the paper phase.
LLM_PROVIDER=deepseek            # anthropic | deepseek

# DeepSeek (default provider). Get a key at https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Anthropic / Claude (alternative provider). Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Execution mode: paper (default, simulated, no real money) or live.
MODE=paper
BANKROLL=1000

# --- Live mode only (Polymarket on Polygon). Never commit real values. ---
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# --- Strategy knobs ---
KELLY_FRACTION=0.25
MAX_TRADE_PCT=0.05
MAX_EXPOSURE_PCT=0.5
MIN_LIQUIDITY=500
MIN_VOLUME_24H=1000
EDGE_THRESHOLD=0.05
CONFIDENCE_THRESHOLD=0.6
BRAIN_WEIGHT=0.3
BRAIN_VETO_THRESHOLD=0.35
MAX_SLIPPAGE=0.02
MIN_DAYS_TO_RESOLUTION=1
MAX_DAYS_TO_RESOLUTION=30

# --- Strategy: scalp (close within minutes at the real price) or resolve (hold to event) ---
STRATEGY=scalp
MAX_HOLD_SECONDS=300      # close a scalp after this long if no target/stop hit (5 min)
TAKE_PROFIT=0.02          # close in profit once the price moved this much our way
STOP_LOSS=0.03            # cap the loss once the price moved this much against us
MIN_NET_PROFIT=0.005      # required profit AFTER spread to even open a scalp
MIN_SPREAD_COST=0.01      # floor for the round-trip spread charged on a paper exit
